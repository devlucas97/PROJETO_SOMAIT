# ── Segurança ────────────────────────────────────────────────────
# OBRIGATÓRIO em produção: gere com `python -c "import secrets; print(secrets.token_hex(32))"`
FLASK_SECRET_KEY=troque-esta-chave-em-producao

# Credenciais de acesso (altere antes de usar)
APP_USERNAME=admin
APP_PASSWORD=troque-esta-senha

# ── Flask ────────────────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Upload ───────────────────────────────────────────────────────
UPLOAD_MAX_MB=5

# ── Planilha Excel ───────────────────────────────────────────────
# Caminho da planilha corporativa (deixe vazio para desativar integração)
PLANILHA_EMPRESA=
ABA_PLANILHA_EMPRESA=Devolucoes

# Mapeamento de colunas customizado (opcional)
# Formato: campo=Nome da Coluna;campo2=Outra Coluna
MAPEAMENTO_COLUNAS_PLANILHA=

# ── Paginação ────────────────────────────────────────────────────
REGISTROS_POR_PAGINA=30

# ── Email / Outlook ──────────────────────────────────────────────
EMAIL_DELL=pon.commercial@dell.com
CNPJ_EMPRESA=09.611.669/0009-41
