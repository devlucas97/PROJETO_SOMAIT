# ── Credenciais ────────────────────────────────────────────
# IMPORTANTE: troque os valores abaixo antes de compartilhar a aplicação.
APP_USERNAME=admin
APP_PASSWORD=troque_esta_senha

# ── Flask ──────────────────────────────────────────────────
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=troque-esta-chave-antes-de-usar
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Upload ─────────────────────────────────────────────────
UPLOAD_MAX_MB=5

# ── Paginação ──────────────────────────────────────────────
REGISTROS_POR_PAGINA=30

# ── Planilha Excel (opcional) ──────────────────────────────
# Caminho absoluto para a planilha corporativa.
# No Windows: C:\Users\seu.usuario\Downloads\devolucoes.xlsx
# No Linux:   /home/usuario/devolucoes.xlsx
PLANILHA_EMPRESA=
ABA_PLANILHA_EMPRESA=Devolucoes
MAPEAMENTO_COLUNAS_PLANILHA=

# ── E-mail (Windows com Outlook) ──────────────────────────
EMAIL_RH=rh@empresa.com.br
EMAIL_DELL=pon.commercial@dell.com
CNPJ_EMPRESA=00.000.000/0000-00

# ── Rate limiting de login ─────────────────────────────────
LOGIN_MAX_TENTATIVAS=5
LOGIN_BLOQUEIO_SEGUNDOS=60
